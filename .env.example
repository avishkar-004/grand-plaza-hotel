# Application Configuration
APP_NAME="Hotel Management System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hotel_management_db
DB_USERNAME=root
DB_PASSWORD=onlinesals.ai

# Security Configuration
APP_KEY=
SESSION_LIFETIME=120
SESSION_DRIVER=file
SESSION_SECURE=false

# Logging
LOG_CHANNEL=single
LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log

# For Review-2: Vulnerable Mode (intentional vulnerabilities)
SECURITY_MODE=vulnerable
# For Review-3: Secure Mode
# SECURITY_MODE=secure

# CSRF Protection
CSRF_ENABLED=false
# Set to true for Review-3

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Password Hashing
PASSWORD_ALGO=BCRYPT
PASSWORD_COST=12

# HTTPS/TLS
FORCE_HTTPS=false
# Set to true for Review-3

# CORS Configuration
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=*

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# Email Configuration (for future use)
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@hotel.local
MAIL_FROM_NAME="${APP_NAME}"
