{
    "name": "ese-project/hotel-management-system",
    "description": "Professional Hotel Management System - ESE Security Audit Project",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "ESE Team",
            "email": "team@eseproject.local"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-mysqli": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Controllers\\": "src/Controllers/",
            "App\\Services\\": "src/Services/",
            "App\\Repositories\\": "src/Repositories/",
            "App\\Models\\": "src/Models/",
            "App\\Middleware\\": "src/Middleware/",
            "App\\Validators\\": "src/Validators/",
            "App\\Core\\": "src/Core/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "phpunit",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
